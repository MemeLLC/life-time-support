{
  "name": "@life-time-support/landing-page",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "dev:cloudflare": "astro build --watch && wrangler pages dev ./dist",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "deploy": "astro build && wrangler pages deploy dist --project-name=landing-page",
    "lighthouse": "astro build && lhci autorun"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@hookform/resolvers": "^5.2.2",
    "@life-time-support/components": "workspace:*",
    "@life-time-support/types": "workspace:*",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^5.16.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "libphonenumber-js": "^1.12.36",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.0.18",
    "jsdom": "^27.4.0",
    "tw-animate-css": "^1.4.0",
    "vitest": "^4.0.18"
  }
}
