---
import "@styles/global.css";
import GoogleTagManager from "./GoogleTagManager.astro";
import GoogleTagManagerNoScript from "./GoogleTagManagerNoScript.astro";
import Metadata from "./Metadata.astro";
import type { Metadata as MetadataType } from "@lib/metadata.types";

interface Props {
  metadata: MetadataType;
  className?: string;
}

const { metadata, className } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <Metadata metadata={metadata} />
    {import.meta.env.DEV && (
      <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet" />
      <style>:root { --font-noto-sans-jp: 'Noto Sans JP', sans-serif; }</style>
    )}
    <GoogleTagManager />
  </head>
  <body class={className}>
    <GoogleTagManagerNoScript />
    <slot />
  </body>
</html>
