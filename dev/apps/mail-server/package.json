{
  "name": "@life-time-support/mail-server",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "echo 'No build step for mail-server (deployed via wrangler deploy)'",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "email:dev": "email dev --dir src/emails --port 3000"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.2",
    "@life-time-support/types": "workspace:*",
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "hono": "^4.11.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260218.0",
    "@hono/swagger-ui": "^0.5.3",
    "@react-email/preview-server": "5.2.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.0.18",
    "react-email": "^5.2.8",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  }
}
