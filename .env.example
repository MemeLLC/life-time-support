# ===========================================
# AI
# ===========================================
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ===========================================
# Google - PageSpeed Insights
# ===========================================
PAGE_SPEED_INSIGHTS_API_KEY="YOUR_PAGE_SPEED_INSIGHTS_API_KEY"

# ===========================================
# Google Cloud - サービスアカウント (GA4 / Search Console 共用)
# GCPコンソール → 認証情報 → サービスアカウント → JSONキーから取得
# ===========================================
GCP_CLIENT_EMAIL="service-account@your-project.iam.gserviceaccount.com"
GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ===========================================
# Google Analytics 4 (GA4)
# GA4管理画面 → プロパティ設定 → プロパティID（数字のみ）
# ===========================================
GA4_PROPERTY_ID="123456789"

# ===========================================
# Google Search Console
# ドメインプロパティの場合: sc-domain:example.com
# URLプレフィックスの場合: https://example.com
# ===========================================
GSC_SITE_URL="sc-domain:example.com"

# ===========================================
# Google Ads
# Developer Token: Google Ads管理画面 → ツールと設定 → APIセンター
# Client ID / Secret: GCPコンソール → 認証情報 → OAuth 2.0 クライアントID
# Refresh Token: OAuth2認可フローで取得（無期限）
# Customer ID: 広告アカウントID（ハイフンなし10桁）
# ===========================================
GOOGLE_ADS_DEVELOPER_TOKEN="YOUR_DEVELOPER_TOKEN"
GOOGLE_ADS_CLIENT_ID="123456789-xxxxx.apps.googleusercontent.com"
GOOGLE_ADS_CLIENT_SECRET="YOUR_CLIENT_SECRET"
GOOGLE_ADS_REFRESH_TOKEN="YOUR_REFRESH_TOKEN"
GOOGLE_ADS_CUSTOMER_ID="1234567890"
